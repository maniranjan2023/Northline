GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key
AVIATIONSTACK_API_KEY=your_aviationstack_api_key
OPENWEATHER_API_KEY=your_openweather_api_key

# Long-term memory (Mem0) — https://docs.mem0.ai/integrations/langgraph
MEM0_API_KEY=your_mem0_api_key
MEM0_ENABLED=true
MEMORY_TOP_K=8

# Short-term memory (LangGraph PostgresSaver) — Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# LangSmith observability (https://docs.langchain.com/langsmith/trace-with-langgraph)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=voyager-ai-travel
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=your_workspace_id
# Flush traces before Streamlit reruns (official LangSmith guidance for short-lived runs)
LANGCHAIN_CALLBACKS_BACKGROUND=false

# Guardrails
GUARDRAILS_ENABLED=true
GUARDRAIL_MODEL=llama-3.1-8b-instant

# Evaluations (see evals/README.md)
# EVAL_LIVE=1
# EVAL_THRESHOLD=0.7
# DEEPEVAL_JUDGE_MODEL=llama-3.3-70b-versatile
