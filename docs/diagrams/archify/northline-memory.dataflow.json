    { "id": "retrieve", "type": "backend", "label": "retrieve_memory", "sublabel": "Mem0 search", "stage": 1, "row": 1 },
    { "id": "context", "type": "messagebus", "label": "memory_context", "sublabel": "state field", "stage": 1, "row": 3 },
    { "id": "agents", "type": "backend", "label": "6 Agents", "sublabel": "read context", "stage": 2, "row": 1 },
    { "id": "checkpoint", "type": "database", "label": "PostgresSaver", "sublabel": "thread_id", "stage": 3, "row": 0 },
    { "id": "extract", "type": "backend", "label": "Extractor", "sublabel": "LLM facts", "stage": 3, "row": 2 },
