{
  "schema_version": 1,
  "diagram_type": "sequence",
  "meta": {
    "title": "Voyager AI — LangSmith Observability",
    "subtitle": "Trace LangGraph runs with metadata and tags",
    "output": "voyager-observability.html",
    "viewBox": [920, 720]
  },
  "participants": [
    { "id": "ui", "type": "frontend", "label": "Streamlit", "sublabel": "frontend" },
    { "id": "obs", "type": "security", "label": "observability", "sublabel": "bootstrap" },
    { "id": "graph", "type": "backend", "label": "LangGraph", "sublabel": "6 agents" },
    { "id": "mcp", "type": "messagebus", "label": "MCP", "sublabel": "tools" },
    { "id": "smith", "type": "cloud", "label": "LangSmith", "sublabel": "dashboard" }
  ],
  "segments": [
    { "from": 160, "to": 280, "label": "01 / BOOT" },
    { "from": 300, "to": 580, "label": "02 / TRIP RUN" }
  ],
  "messages": [
    { "from": "ui", "to": "obs", "y": 180, "label": "configure_langsmith", "variant": "emphasis" },
    { "from": "obs", "to": "ui", "y": 220, "label": "tracing on", "variant": "return" },
    { "from": "ui", "to": "graph", "y": 320, "label": "app.stream", "variant": "emphasis" },
    { "from": "graph", "to": "smith", "y": 370, "label": "root trace", "variant": "dashed" },
    { "from": "graph", "to": "mcp", "y": 420, "label": "tool calls", "variant": "default" },
    { "from": "mcp", "to": "graph", "y": 470, "label": "results", "variant": "return" },
    { "from": "graph", "to": "smith", "y": 520, "label": "agent spans", "variant": "dashed" },
    { "from": "graph", "to": "ui", "y": 570, "label": "itinerary", "variant": "return" }
  ],
  "activations": [
    { "participant": "graph", "from": 340, "to": 550, "type": "backend" }
  ],
  "cards": [
    { "dot": "cyan", "title": "Traced", "items": ["travel_planning root run", "Each agent node as child span", "ChatGroq LLM calls nested"] },
    { "dot": "emerald", "title": "Metadata", "items": ["user_id, thread_id, app=voyager-ai", "tags: voyager-ai, langgraph, streamlit"] }
  ]
}
